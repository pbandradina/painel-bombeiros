{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/trpc.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/trpc/(.*)",
      "destination": "/api/trpc.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/trpc.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
