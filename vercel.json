{
  "version": 2,
  "buildCommand": "npm run build && echo 'Build complete'",
  "outputDirectory": "dist",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api.mjs": {
      "runtime": "nodejs22.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/trpc/(.*)",
      "destination": "/api.mjs"
    },
    {
      "source": "/api/health",
      "destination": "/api.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
